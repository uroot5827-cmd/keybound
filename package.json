{
    "name": "keybound",
    "version": "0.0.1",
    "private": true,
    "description": "Framework-agnostic keyboard shortcut engine",
    "keywords": [
        "framework-agnostic",
        "hotkeys",
        "keybind",
        "keybinding",
        "keyboard",
        "keyboard-engine",
        "keyboard-shortcuts",
        "shortcuts"
    ],
    "homepage": "https://github.com/uroot5827-cmd/keybound#readme",
    "bugs": {
        "url": "https://github.com/uroot5827-cmd/keybound/issues"
    },
    "license": "MIT",
    "author": "xun",
    "repository": {
        "type": "git",
        "url": "https://github.com/uroot5827-cmd/keybound"
    },
    "type": "module",
    "scripts": {
        "=== 格式化 & 检查 ===": "echo",
        "format": "oxfmt --write --config .config/format/oxfmt.json",
        "check:format": "oxfmt --check --config .config/format/oxfmt.json",
        "lint": "eslint . --fix --config .config/lint/eslint.config.ts",
        "check:lint": "eslint . --config .config/lint/eslint.config.ts",
        "check:deps": "knip --config .config/analysis/knip.ts",
        "check": "run-s check:lint check:format",
        "=== 测试 ===": "echo",
        "test": "vitest",
        "test:run": "vitest run",
        "=== 构建 ===": "echo",
        "build": "pnpm -r build",
        "check:types": "pnpm -r check:types",
        "=== 文档 ===": "echo",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "=== 开发 ===": "echo",
        "clean": "rm -rf packages/*/dist",
        "clean:deep": "pnpm store prune && pnpm prune && pnpm dedupe",
        "check:system": "pnpm doctor && echo '=== Store Status ===' && pnpm store status && echo '=== Security Audit ===' && pnpm audit && echo '=== Outdated Packages ===' && pnpm outdated"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/types": "^20.5.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/coverage-v8": "^4.1.3",
        "eslint": "^9.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-unicorn": "^64.0.0",
        "knip": "^6.3.0",
        "lefthook": "^2.1.5",
        "npm-run-all": "^4.0.0",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "typescript": "^6.0.2",
        "vite": "^7.3.1",
        "vitest": "^4.1.3"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@9.14.4"
}
